{
    "configurations": [
        {
            "name": "x64-MSVC",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/include/core",
                "${workspaceFolder}/include/ui",
                "${workspaceFolder}/include/utils",
                "${workspaceFolder}/src",
                "${workspaceFolder}/res"
            ],
            "defines": [
                "UNICODE",
                "_UNICODE",
                "_WIN32_WINNT=0x0601",
                "WIN32_LEAN_AND_MEAN",
                "NOMINMAX"
            ],
            "windowsSdkVersion": "10.0.22621.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64"
        }
    ],
    "version": 4
}
